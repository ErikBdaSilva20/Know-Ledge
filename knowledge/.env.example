# tenant-gateway base URL (required in prod; the edge worker injects it at
# runtime via window.__MASI_GW__ instead — see src/lib/data/client.ts).
VITE_GATEWAY_URL=

# Dev-only: tenant id when running against a local/remote gateway directly
# (prod resolves this from window.__MASI_TENANT__, injected by the edge worker).
VITE_TENANT_ID=

# "mock" (default) keeps every repo on the in-browser mock store (mockDb.ts).
# "gateway" routes every repo through src/lib/data/client.ts's db.table().
# See doc/architecture/01-stack-e-modelagem.md and Story 1.6.
VITE_DATA_SOURCE=mock
