# Copy to `.env.local` (git-ignored) to point the app at the tenant-local
# docker-compose stack (dev/docker-compose.yml) instead of the mock store.
# Never touches src/lib/data/client.ts — same protected file, different config
# (Story 1.3's resolution order already reads these).
VITE_GATEWAY_URL=http://localhost:8787
VITE_TENANT_ID=local-dev
VITE_DATA_SOURCE=gateway
